{
  "name": "telegram-mcp-ts",
  "version": "0.7.0",
  "description": "TypeScript-native, dual-mode (MTProto user account + Bot API) Model Context Protocol server for Telegram.",
  "type": "module",
  "license": "MIT",
  "author": "Sridharan",
  "homepage": "https://github.com/sridharandevcom/telegram-mcp-ts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sridharandevcom/telegram-mcp-ts.git"
  },
  "bugs": {
    "url": "https://github.com/sridharandevcom/telegram-mcp-ts/issues"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "bin": {
    "telegram-mcp-ts": "./dist/index.js",
    "telegram-mcp-ts-auth": "./dist/auth/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "auth": "node dist/auth/cli.js",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "big-integer": "^1.6.52",
    "telegram": "^2.26.22",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "rimraf": "^5.0.7",
    "tsup": "^8.1.0",
    "typescript": "^5.5.3"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "telegram",
    "mtproto",
    "gramjs",
    "bot-api",
    "claude",
    "ai"
  ]
}