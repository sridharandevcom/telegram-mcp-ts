# --- MTProto (personal user account) mode ---
# Get API_ID and API_HASH from https://my.telegram.org -> API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Produced by the one-time auth flow: `npm run auth login`
# This is a long opaque string. Treat it like a password — it grants full account access.
TELEGRAM_SESSION=

# --- Bot API mode ---
# From @BotFather (/newbot). The token IS the credential — no login/session needed.
# Set this to enable the bot tools (get_bot_info, send_bot_message, send_document,
# send_poll, send_inline_keyboard, handle_callback).
# TELEGRAM_BOT_TOKEN=
